{
  "openapi": "3.1.0",
  "info": {
    "title": "Nova Health API",
    "description": "API d'orientation médicale propulsée par l'IA",
    "version": "0.1.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Accueil",
        "description": "Route d'accueil simple pour vérifier que l'API tourne.",
        "operationId": "accueil__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "summary": "Chat Endpoint",
        "description": "Reçoit le message et les coordonnées GPS du patient, \net renvoie l'orientation médicale formatée en JSON.",
        "operationId": "chat_endpoint_api_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/audio": {
      "post": {
        "summary": "Audio Endpoint",
        "operationId": "audio_endpoint_api_audio_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_audio_endpoint_api_audio_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_audio_endpoint_api_audio_post": {
        "properties": {
          "user_lat": {
            "type": "number",
            "title": "User Lat"
          },
          "user_lon": {
            "type": "number",
            "title": "User Lon"
          },
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "user_lat",
          "user_lon",
          "file"
        ],
        "title": "Body_audio_endpoint_api_audio_post"
      },
      "ChatRequest": {
        "properties": {
          "user_message": {
            "title": "User Message"
          },
          "user_lat": {
            "type": "number",
            "title": "User Lat"
          },
          "user_lon": {
            "type": "number",
            "title": "User Lon"
          }
        },
        "type": "object",
        "required": [
          "user_message",
          "user_lat",
          "user_lon"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "intention": {
            "type": "string",
            "title": "Intention"
          },
          "mot_cle": {
            "type": "string",
            "title": "Mot Cle"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "reponse_texte": {
            "title": "Reponse Texte"
          }
        },
        "type": "object",
        "required": [
          "intention",
          "mot_cle",
          "message",
          "reponse_texte"
        ],
        "title": "ChatResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}